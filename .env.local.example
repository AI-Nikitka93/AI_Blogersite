GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
MIRO_LLM_PROVIDER=groq
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MIRO_OPENROUTER_MODEL=z-ai/glm-5.1
MIRO_OPENROUTER_GATEKEEPER_MODEL=z-ai/glm-5.1
# Role-based pipeline. Keep these separate if you want 3-model cooperation.
MIRO_RESEARCH_PROVIDER=openrouter
MIRO_RESEARCH_MODEL=deepseek/deepseek-r1-0528
MIRO_WRITER_PROVIDER=groq
MIRO_WRITER_MODEL=llama-3.3-70b-versatile
MIRO_REVIEW_PROVIDER=groq
MIRO_REVIEW_MODEL=llama-3.1-8b-instant
# NVIDIA NIM serverless API settings. Used when MIRO_LLM_PROVIDER=nvidia.
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
MIRO_NVIDIA_MODEL=z-ai/glm-4.7
MIRO_NVIDIA_GATEKEEPER_MODEL=z-ai/glm-4.7
CRON_SECRET=replace_with_long_random_secret
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
COINGECKO_DEMO_API_KEY=optional_demo_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_USERNAME=@your_channel_username
TELEGRAM_CHANNEL_ID=-1001234567890
MIRO_SITE_URL=https://your-domain.example
MIRO_GATEKEEPER_MODEL=llama-3.1-8b-instant
MIRO_GENERATOR_MODEL=llama-3.3-70b-versatile
MIRO_TOPIC_STRATEGY=editorial_schedule
