GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_HTTP_REFERER=https://your-domain.example
OPENROUTER_X_TITLE=Miro AI_Blogersite
MIRO_LLM_PROVIDER=groq
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MIRO_OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
MIRO_OPENROUTER_GATEKEEPER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Role-based pipeline. Keep these separate if you want 3-model cooperation.
MIRO_RESEARCH_PROVIDER=groq
MIRO_RESEARCH_MODEL=llama-3.3-70b-versatile
MIRO_GATEKEEPER_PROVIDER=groq
MIRO_WRITER_PROVIDER=nvidia
MIRO_WRITER_MODEL=openai/gpt-oss-120b
# Optional fast writer fallback. The existing GROQ_API_KEY can be reused when
# the primary NVIDIA request exceeds its hedge timeout.
MIRO_FALLBACK_WRITER_PROVIDER=groq
MIRO_FALLBACK_WRITER_MODEL=llama-3.3-70b-versatile
MIRO_PRIMARY_WRITER_TIMEOUT_MS=20000
MIRO_MARKETS_GENERATOR_MODEL=llama-3.3-70b-versatile
MIRO_REVIEW_PROVIDER=groq
MIRO_REVIEW_MODEL=llama-3.3-70b-versatile
# NVIDIA NIM serverless API settings. Used when MIRO_LLM_PROVIDER=nvidia.
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
MIRO_NVIDIA_MODEL=openai/gpt-oss-20b
MIRO_NVIDIA_GATEKEEPER_MODEL=openai/gpt-oss-20b
CRON_SECRET=replace_with_long_random_secret
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
COINGECKO_DEMO_API_KEY=optional_demo_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_USERNAME=@your_channel_username
TELEGRAM_CHANNEL_ID=-1001234567890
MIRO_SITE_URL=https://your-domain.example
MIRO_GATEKEEPER_MODEL=llama-3.3-70b-versatile
MIRO_GENERATOR_MODEL=openai/gpt-oss-120b
MIRO_TOPIC_STRATEGY=editorial_schedule
# Optional broad news search. Keep off by default until GDELT latency is stable.
MIRO_ENABLE_GDELT=0
