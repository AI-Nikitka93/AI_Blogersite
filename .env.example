MIRO_OPENROUTER_MODEL=z-ai/glm-5.1
MIRO_OPENROUTER_GATEKEEPER_MODEL=z-ai/glm-5.1
# Role-based pipeline. Keep these separate if you want 3-model cooperation.
MIRO_RESEARCH_PROVIDER=openrouter
MIRO_RESEARCH_MODEL=deepseek/deepseek-r1-0528
