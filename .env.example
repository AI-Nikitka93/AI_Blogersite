SUPABASE_SERVICE_ROLE_KEY=
COINGECKO_DEMO_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_USERNAME=
TELEGRAM_CHANNEL_ID=
